# ====================================
# OpenAI API 配置（必需）
# ====================================
# 申请地址：https://platform.openai.com/
# 注意：需要先充值才能使用
OPENAI_API_KEY=sk-your-openai-api-key-here

# ====================================
# Weaviate 向量数据库配置（必需）
# ====================================
# 申请地址：https://console.weaviate.cloud/
WEAVIATE_URL=https://your-weaviate-cluster.weaviate.network
WEAVIATE_API_KEY=your-weaviate-api-key-here

# ====================================
# PostgreSQL 记录管理数据库（必需）
# ====================================
# 可使用 Supabase：https://supabase.com
# 格式：postgresql://用户名:密码@主机:端口/数据库名
# 示例：postgresql://postgres:password@db.xxxxx.supabase.co:5432/postgres
RECORD_MANAGER_DB_URL=postgresql://username:password@host:port/database

# ====================================
# LangSmith 追踪配置（可选，用于调试）
# ====================================
# 申请地址：https://smith.langchain.com/
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=your-langsmith-api-key-here
LANGCHAIN_PROJECT=chat-langchain-study

# ====================================
# 使用说明
# ====================================
# 1. 复制此文件为 .env
# 2. 将上述所有 "your-xxx-here" 替换为实际的 API 密钥
# 3. 确保 .env 文件不要提交到 Git（已在 .gitignore 中）
